# MongoDB Connection String
# Get your free cluster at: https://www.mongodb.com/cloud/atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/medtracker

# Server Port
PORT=5000

# Node Environment (development | production)
NODE_ENV=development

# JWT Configuration — REQUIRED. Use a strong random string.
JWT_SECRET=change-this-to-a-very-long-random-secret-string
JWT_EXPIRE=7d

# Email Configuration
# Option 1: Gmail (use App Password, not your regular password)
# EMAIL_SERVICE=gmail
# Option 2: Custom SMTP (Ethereal for testing — https://ethereal.email)
EMAIL_HOST=smtp.ethereal.email
EMAIL_PORT=587
EMAIL_USER=your-email@ethereal.email
EMAIL_PASS=your-email-password
EMAIL_FROM=noreply@pulseconnect.health

# Frontend URL (update for production deployment)
FRONTEND_URL=http://localhost:3000

# Allowed CORS Origins (comma-separated, no spaces)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Refill Alert Threshold (minimum pills remaining before alerting)
REFILL_THRESHOLD=5

# Cron Job Timezone (list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
# Example: Asia/Kolkata, America/New_York, Europe/London, UTC
CRON_TIMEZONE=UTC

# Google Gemini AI API Key
# Get your free API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
